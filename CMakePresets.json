{
  "version": 5,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "config_common",
      "description": "Common configuration settings for all configurations",
      "hidden": true,
      "generator": "Unix Makefiles",
      "warnings": {
        "dev": true,
        "deprecated": true,
        "uninitialized": false
      },
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": true
      }
    },
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with full sanitizers and tests",
      "hidden": false,
      "inherits": "config_common",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": true,
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -g3 -fstack-protector-all -fcf-protection=full -fsanitize=address -fsanitize=undefined -fsanitize=leak -D_GLIBCXX_ASSERTIONS -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE"
      }
    },
    {
      "name": "debug-ninja",
      "displayName": "Debug (Ninja)",
      "description": "Debug build with Ninja and full sanitizers",
      "hidden": false,
      "inherits": "debug",
      "generator": "Ninja"
    },
    {
      "name": "debug-macos",
      "displayName": "Debug (macOS)",
      "description": "Debug build for macOS with sanitizers",
      "hidden": false,
      "inherits": "config_common",
      "binaryDir": "${sourceDir}/build/debug-macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": true,
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -g3 -fstack-protector-all -fsanitize=address -fsanitize=undefined -D_GLIBCXX_ASSERTIONS -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE"
      }
    },
    {
      "name": "debug-nosan",
      "displayName": "Debug (No Sanitizers)",
      "description": "Debug build without sanitizers for faster iteration",
      "hidden": false,
      "inherits": "config_common",
      "binaryDir": "${sourceDir}/build/debug-nosan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "BUILD_TESTS": true,
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -g3 -D_GLIBCXX_ASSERTIONS -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release build with optimizations",
      "hidden": false,
      "inherits": "config_common",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -O3 -DNDEBUG -D_GLIBCXX_ASSERTIONS -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE"
      }
    },
    {
      "name": "release-ninja",
      "displayName": "Release (Ninja)",
      "description": "Release build with Ninja",
      "hidden": false,
      "inherits": "release",
      "generator": "Ninja"
    },
    {
      "name": "release-static",
      "displayName": "Release (Static)",
      "description": "Release build with static linking",
      "hidden": false,
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/release-static",
      "cacheVariables": {
        "Boost_USE_STATIC_LIBS": "ON",
        "CMAKE_FIND_LIBRARY_SUFFIXES": ".a",
        "BUILD_SHARED_LIBS": false,
        "CMAKE_EXE_LINKER_FLAGS": "-static"
      }
    },
    {
      "name": "minsize",
      "displayName": "MinSizeRel",
      "description": "Release build optimized for size",
      "hidden": false,
      "inherits": "config_common",
      "binaryDir": "${sourceDir}/build/minsize",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel",
        "CMAKE_CXX_FLAGS": "-Wall -Wextra -Os -DNDEBUG -D_GLIBCXX_ASSERTIONS -D_LIBCPP_HARDENING_MODE=_LIBCPP_HARDENING_MODE_EXTENSIVE"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "displayName": "Debug build",
      "configurePreset": "debug"
    },
    {
      "name": "debug-ninja",
      "displayName": "Debug (Ninja) build",
      "configurePreset": "debug-ninja"
    },
    {
      "name": "debug-macos",
      "displayName": "Debug (macOS) build",
      "configurePreset": "debug-macos"
    },
    {
      "name": "debug-nosan",
      "displayName": "Debug (No San) build",
      "configurePreset": "debug-nosan"
    },
    {
      "name": "release",
      "displayName": "Release build",
      "configurePreset": "release"
    },
    {
      "name": "release-ninja",
      "displayName": "Release (Ninja) build",
      "configurePreset": "release-ninja"
    },
    {
      "name": "release-static",
      "displayName": "Release (Static) build",
      "configurePreset": "release-static"
    },
    {
      "name": "minsize",
      "displayName": "MinSizeRel build",
      "configurePreset": "minsize"
    },
    {
      "name": "format",
      "displayName": "Run clang-format",
      "configurePreset": "release",
      "targets": ["clang-format"]
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "displayName": "Debug tests",
      "configurePreset": "debug",
      "output": {
        "verbosity": "default",
        "labelSummary": false
      }
    },
    {
      "name": "debug-ninja",
      "displayName": "Debug (Ninja) tests",
      "configurePreset": "debug-ninja",
      "output": {
        "verbosity": "default",
        "labelSummary": false
      }
    },
    {
      "name": "debug-nosan",
      "displayName": "Debug (No San) tests",
      "configurePreset": "debug-nosan",
      "output": {
        "verbosity": "default",
        "labelSummary": false
      }
    }
  ]
}
